# Copier ce fichier en .env et remplir les vraies valeurs.
# Ne JAMAIS commiter le fichier .env (voir .gitignore).

NODE_ENV=development
PORT=3001

# Base de données (fournie automatiquement par Railway en prod)
DATABASE_URL=postgresql://user:password@localhost:5432/plateforme_etudiante

# Auth
JWT_SECRET=change-me-in-production

# À activer seulement après l'intégration du module auth/JWT :
# les paiements doivent être créés par un utilisateur authentifié et autorisé
# pour le dossier concerné.

# Frontend (pour les redirections après paiement, etc.)
FRONTEND_URL=http://localhost:3000

# Paiements (à remplir quand vous testerez le module paiements)
# Clé secrète Stripe (Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=
# Secret du webhook (Dashboard > Developers > Webhooks > votre endpoint)
STRIPE_WEBHOOK_SECRET=

# PayPal (Developer Dashboard > Apps & Credentials)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Id du webhook créé dans Developer Dashboard > Webhooks
PAYPAL_WEBHOOK_ID=

# Mobile Money via CinetPay (unifie MTN MoMo, Airtel Money...)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=

# URL publique de l'API, utilisée pour construire les notify_url des
# webhooks (ex: CinetPay a besoin de connaître cette URL à l'avance)
API_URL=http://localhost:3001

# Monitoring (à remplir quand Sentry sera branché)
SENTRY_DSN=
